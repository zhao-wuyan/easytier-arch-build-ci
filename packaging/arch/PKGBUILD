# Maintainer: you <you@example.com>

pkgbase=easytier
pkgname=(
  'easytier'
  'easytier-gui'
)
pkgver=2.4.5
pkgrel=1
arch=('x86_64')
url="https://github.com/EasyTier/EasyTier"
license=('LGPL3')

makedepends=(
  # rust
  'rust'
  'cargo'
  'protobuf'
  'git'
  'clang'
  'llvm'
  'pkgconf'

  # zstd (system)
  'zstd'

  # gui build
  'nodejs'
  'pnpm'
  'python'

  # tauri / webkit
  'webkit2gtk-4.1'
  'javascriptcoregtk-4.1'
  'gtk3'
  'librsvg'
  'libayatana-appindicator'
)

source=("${pkgbase}-${pkgver}.tar.gz::https://github.com/EasyTier/EasyTier/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('SKIP')

prepare() {
  cd "EasyTier-${pkgver}"

  # speed up rebuilds in CI by placing pnpm store under $srcdir (which is cacheable)
  export PNPM_STORE_PATH="${srcdir}/pnpm-store"
  pnpm config set store-dir "${PNPM_STORE_PATH}"
}

build() {
  cd "EasyTier-${pkgver}"

  export CARGO_HOME="${srcdir}/cargo-home"
  export CARGO_TARGET_DIR="${srcdir}/target"

  # Arch's makepkg toolchain flags may enable GCC LTO and lld at the same time.
  # Some Rust crates build C deps (ring/kcp) with $CFLAGS; if those become GCC-LTO
  # objects, lld may fail to link them, causing missing symbols.
  export CFLAGS="${CFLAGS//-flto=auto/}"
  export CXXFLAGS="${CXXFLAGS//-flto=auto/}"
  export LDFLAGS="${LDFLAGS//-flto=auto/}"
  export LDFLAGS="${LDFLAGS//-fuse-ld=lld/}"

  # kcp-sys uses bindgen -> needs libclang
  if command -v llvm-config >/dev/null; then
    export LIBCLANG_PATH="$(llvm-config --libdir)"
  fi

  # zstd-sys can use system libzstd via pkg-config
  export ZSTD_SYS_USE_PKG_CONFIG=1

  # CI/Node build may crash when loading vite-plugin-vue-devtools (it assumes browser localStorage).
  # This plugin is only for development, so strip it for packaging builds.
  sed -i "/vite-plugin-vue-devtools/d" easytier-gui/vite.config.ts
  sed -i "/VueDevTools()/d" easytier-gui/vite.config.ts

  export PNPM_STORE_PATH="${srcdir}/pnpm-store"
  pnpm config set store-dir "${PNPM_STORE_PATH}"

  # Allow dependency install scripts in CI (esbuild, etc.)
  pnpm config set dangerouslyAllowAllBuilds true

  # Some dependencies assume browser localStorage even during Node-side config loading.
  # Provide a minimal polyfill for the build process.
  cat > "${srcdir}/localstorage-polyfill.mjs" <<'EOF'
if (typeof globalThis.localStorage === 'undefined') {
  const store = new Map();
  globalThis.localStorage = {
    getItem: (k) => (store.has(String(k)) ? store.get(String(k)) : null),
    setItem: (k, v) => { store.set(String(k), String(v)); },
    removeItem: (k) => { store.delete(String(k)); },
    clear: () => { store.clear(); },
    key: (i) => Array.from(store.keys())[i] ?? null,
    get length() { return store.size; },
  };
}
EOF
  export NODE_OPTIONS="--import ${srcdir}/localstorage-polyfill.mjs"

  pnpm install --frozen-lockfile
  pnpm --dir easytier-web/frontend-lib build
  pnpm --dir tauri-plugin-vpnservice build

  cargo build --release --locked -p easytier --bin easytier-core --bin easytier-cli
  cargo build --release --locked -p easytier-web --bin easytier-web

  pnpm --dir easytier-gui build
  pnpm --dir easytier-gui tauri build --no-bundle
}

package_easytier() {
  pkgdesc="EasyTier core/cli/web"
  depends=('zstd')

  install -Dm755 "${srcdir}/target/release/easytier-core" "${pkgdir}/usr/bin/easytier-core"
  install -Dm755 "${srcdir}/target/release/easytier-cli"  "${pkgdir}/usr/bin/easytier-cli"
  install -Dm755 "${srcdir}/target/release/easytier-web"  "${pkgdir}/usr/bin/easytier-web"

  install -Dm644 "${srcdir}/EasyTier-${pkgver}/LICENSE" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}

package_easytier-gui() {
  pkgdesc="EasyTier GUI"
  depends=(
    'zstd'
    'webkit2gtk-4.1'
    'javascriptcoregtk-4.1'
    'gtk3'
    'librsvg'
    'libayatana-appindicator'
  )

  local gui_bin="${srcdir}/target/release/easytier-gui"
  if [[ ! -f "${gui_bin}" ]]; then
    gui_bin="${srcdir}/EasyTier-${pkgver}/easytier-gui/src-tauri/target/release/easytier-gui"
  fi

  install -Dm755 "${gui_bin}" "${pkgdir}/usr/bin/easytier-gui"
  install -Dm644 "${srcdir}/EasyTier-${pkgver}/easytier-gui/src-tauri/icons/icon.png" "${pkgdir}/usr/share/pixmaps/easytier-gui.png"
  install -Dm644 "${startdir}/easytier-gui.desktop" "${pkgdir}/usr/share/applications/easytier-gui.desktop"

  install -Dm644 "${srcdir}/EasyTier-${pkgver}/LICENSE" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
